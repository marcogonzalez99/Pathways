---
import '../styles/global.css'
---

<div class="flex flex-col items-center justify-center gap-4 text-center">
    <h1 class="text-9xl font-bold text-(--color-text-main) animate-[fade-up_0.4s_ease-out_both]">404</h1>
    <p class="text-2xl font-semibold text-(--color-text-main) animate-[fade-up_0.4s_ease-out_both]" style="animation-delay: 0.1s">This path doesn't exist.</p>
    <p class="text-(--color-text-secondary) max-w-xs animate-[fade-up_0.4s_ease-out_both]" style="animation-delay: 0.2s">The page you're looking for has moved, or never existed.</p>
    <a href="/" class="mt-2 px-6 py-3 rounded-full border-2 border-(--color-text-main) text-(--color-text-main) font-semibold hover:scale-105 transition-transform duration-200 animate-[fade-up_0.4s_ease-out_both]" style="animation-delay: 0.3s">
        Back to Main Profile
    </a>
</div>
